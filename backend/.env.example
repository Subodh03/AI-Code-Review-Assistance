# Server
PORT=5000
NODE_ENV=development
FRONTEND_URL=http://localhost:5173

# PostgreSQL
# Option 1: a single connection string. NOTE: if your password contains
# special characters (@ : / # % or a space), they must be URL-encoded here,
# e.g. "p@ss" becomes "p%40ss" -- see README for the full encoding table.
DATABASE_URL=postgresql://postgres:postgres@localhost:5432/code_review_assistant

# Option 2 (recommended if your password has special characters): comment out
# DATABASE_URL above and fill these in instead -- no encoding needed.
# PGHOST=localhost
# PGPORT=5432
# PGUSER=postgres
# PGPASSWORD=postgres
# PGDATABASE=code_review_assistant

# JWT
JWT_SECRET=replace-with-a-long-random-string
JWT_EXPIRES_IN=7d

# OpenRouter (AI review)
OPENROUTER_API_KEY=sk-or-xxxxxxxxxxxxxxxxxxxxxxxx
OPENROUTER_MODEL=anthropic/claude-3.5-sonnet

# Uploads
MAX_UPLOAD_SIZE_MB=5
